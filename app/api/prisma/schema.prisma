generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String    @id @default(cuid())
  phone       String    @unique
  fullName    String
  email       String?
  role        String
  idVerified  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  properties  Property[]
}

model Property {
  id            String   @id @default(cuid())
  hostId        String
  title         String
  description   String
  city          String
  address       String
  lat           Float?
  lng           Float?
  maxGuests     Int
  bedrooms      Int
  bathrooms     Int
  pricePerNight Int
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  host          User     @relation(fields: [hostId], references: [id])
  photos        Photo[]
}

model Photo {
  id          String   @id @default(cuid())
  url         String
  isCover     Boolean
  order       Int
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id])
}